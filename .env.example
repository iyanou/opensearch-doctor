# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env on the production server and fill in every value.
# Never commit .env to git.
#
# On the server:
#   cp .env.example .env
#   nano .env          # fill in real values
#   chmod 600 .env     # restrict read access to current user only
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE — PostgreSQL installed on the same server
# Create the database and user first:
#   sudo -u postgres psql
#   CREATE USER osduser WITH PASSWORD 'strongpassword';
#   CREATE DATABASE opensearch_doctor OWNER osduser;
#   \q
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/opensearch_doctor
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/opensearch_doctor

# NEXTAUTH — generate a 64-char secret with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://yourdomain.com

# GOOGLE OAUTH — production client (separate from dev)
# Authorised redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# STRIPE — live keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
# Register webhook: https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# CRON — protects /api/cron/* from public access
# Generate with: openssl rand -hex 32
# Paste the same value into crontab.example curl commands
CRON_SECRET=

# RESEND — verified domain required to avoid spam
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

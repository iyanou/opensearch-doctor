# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env on the production server and fill in every value.
# Never commit .env to git.
#
# On the server:
#   cp .env.example .env
#   nano .env          # fill in real values
#   chmod 600 .env     # restrict read access to current user only
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE — PostgreSQL installed on the same server
# Create the database and user first:
#   sudo -u postgres psql
#   CREATE USER osduser WITH PASSWORD 'strongpassword';
#   CREATE DATABASE opensearch_doctor OWNER osduser;
#   \q
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/opensearch_doctor
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/opensearch_doctor

# NEXTAUTH — generate a 64-char secret with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://yourdomain.com

# GOOGLE OAUTH — production client (separate from dev)
# Authorised redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PAYPAL — live credentials from developer.paypal.com
# 1. Create a PayPal Business account
# 2. Go to developer.paypal.com → My Apps & Credentials → Live
# 3. Create an app and copy Client ID + Secret
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PAYPAL PLAN IDs — create 3 subscription plans in PayPal (via API or dashboard)
# Product: Starter ($39/mo)
PAYPAL_STARTER_PLAN_ID=P-...
# Product: Pro ($99/mo)
PAYPAL_PRO_PLAN_ID=P-...
# Product: Scale ($199/mo)
PAYPAL_SCALE_PLAN_ID=P-...

# PAYPAL WEBHOOK — register at developer.paypal.com → Webhooks
# URL: https://yourdomain.com/api/webhooks/paypal
# Events: BILLING.SUBSCRIPTION.*, PAYMENT.SALE.*
PAYPAL_WEBHOOK_ID=

# CRON — protects /api/cron/* from public access
# Generate with: openssl rand -hex 32
# Paste the same value into crontab.example curl commands
CRON_SECRET=

# RESEND — verified domain required to avoid spam
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# SUPPORT — inbox that receives contact form submissions
SUPPORT_EMAIL=support@opensearchdoctor.com

# SENTRY — error tracking (optional but strongly recommended for production)
# Create project at sentry.io → Settings → Projects → your-project → DSN
SENTRY_DSN=https://...@sentry.io/...

# PUBLIC URL — used in metadata and OG tags (no trailing slash)
NEXT_PUBLIC_APP_URL=https://opensearchdoctor.com

# PLAUSIBLE — privacy-friendly analytics (optional, no cookies, no GDPR banner needed)
# Create account at plausible.io, add your domain, then set it here
# Leave blank to disable analytics entirely
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=opensearchdoctor.com

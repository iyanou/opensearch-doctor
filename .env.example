# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically on deploy)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/opensearch_doctor

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
# Public URL of your deployed app (no trailing slash)
NEXTAUTH_URL=https://your-app.railway.app

# Google OAuth (optional — enables "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Live key for production, test key (sk_test_...) for staging
STRIPE_SECRET_KEY=sk_live_...
# Price ID for the Pro monthly subscription product
STRIPE_PRO_PRICE_ID=price_...
# From Stripe dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cron job protection ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Used as Bearer token when calling /api/cron/* endpoints
CRON_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── Email (Resend) ────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_...
# Verified sender domain — must match a verified domain in Resend
RESEND_FROM_EMAIL=alerts@yourdomain.com
